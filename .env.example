# Required
SECRET_KEY=change-this-to-a-random-secret-key
DATABASE_URL=sqlite:///bsphcl.db

# Email (optional — OTP shown on screen if not configured)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=

# Cloudinary (optional — local disk used if not configured)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App settings
FLASK_ENV=development
OTP_EXPIRY_MINUTES=10
